# Equity Treasury Agent — environment
# Copy to .env and fill in.
#
# Network is opt-in: set HEDERA_NETWORK and you operate on that network, at your own
# risk. testnet (default) uses test HBAR; mainnet moves real value and is irreversible.
# When set to mainnet, also point the endpoints + ATS factory/resolver at mainnet values.

# --- Hedera operator (ECDSA, required) ---
HEDERA_NETWORK=testnet
HEDERA_OPERATOR_ID=0.0.XXXXXXX
HEDERA_OPERATOR_KEY=<64-char-hex-raw-ecdsa-private-key>
HEDERA_OPERATOR_KEY_TYPE=ECDSA
HEDERA_OPERATOR_PUBLIC_KEY=<compressed-public-key-hex>
HEDERA_OPERATOR_EVM_ADDRESS=<0x-evm-address>

# --- ATS reference deployment (public testnet factory + resolver) ---
ATS_FACTORY_ADDRESS=0.0.7512002
ATS_RESOLVER_ADDRESS=0.0.7511642

# --- Hedera endpoints ---
# Defaults follow HEDERA_NETWORK when omitted. For mainnet use e.g.:
#   HEDERA_MIRROR_NODE_URL=https://mainnet-public.mirrornode.hedera.com
#   HEDERA_RPC_URL=https://mainnet.hashio.io/api
HEDERA_MIRROR_NODE_URL=https://testnet.mirrornode.hedera.com
HEDERA_RPC_URL=https://testnet.hashio.io/api

# --- HCS securities registry (optional) ---
# Leave blank to create a new registry topic on first use; the tool returns the topic
# id. Set it here to reuse the same registry (name resolution + audit trail) across runs.
HCS_REGISTRY_TOPIC_ID=

# --- LLM provider (google default; set openai to switch) ---
LLM_PROVIDER=google
LLM_MODEL=gemini-2.5-flash
GEMINI_API_KEY=

# OpenAI API or OpenAI-compatible proxy (e.g. local kiro-gateway on EC2):
# LLM_PROVIDER=openai
# LLM_MODEL=claude-haiku-4.5
# OPENAI_API_KEY=<PROXY_API_KEY from ~/kiro-gateway/.env>
# OPENAI_BASE_URL=http://127.0.0.1:8000/v1

# Transient-error retry budget for the LLM client (per-minute 429s, brief 5xx).
# Does not defeat a hard daily quota cap. Defaults to 4 when omitted.
# LLM_MAX_RETRIES=4

# --- Safety policies (enforced by the plugin) ---
MAX_SUPPLY_CAP=1000000
JURISDICTION_ALLOWLIST=US,GB,DE,FR,MA,AE,SG,JP

# --- Demo investor (optional; used by scripted demo + as default holder) ---
INVESTOR_ACCOUNT_ID=0.0.XXXXXXX
INVESTOR_EVM_ADDRESS=<0x-evm-address>
