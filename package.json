{
  "name": "equity-treasury-agent",
  "version": "0.1.0",
  "private": true,
  "description": "LLM-powered enterprise treasury agent that issues and administers tokenized securities on Hedera testnet via the @hebx/hak-ats-plugin Hedera Agent Kit plugin.",
  "type": "module",
  "license": "MIT",
  "bin": {
    "ats-agent": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "format": "prettier --write .",
    "agent": "tsx src/cli.ts",
    "preflight": "tsx src/preflight.ts",
    "plugin:build": "npm --prefix vendor/hak-ats-plugin install && npm --prefix vendor/hak-ats-plugin run build",
    "secrets:scan": "gitleaks detect --no-banner --source ."
  },
  "dependencies": {
    "@hashgraph/hedera-agent-kit": "^4.0.0",
    "@hashgraph/hedera-agent-kit-langchain": "^1.0.0",
    "@hebx/hak-ats-plugin": "file:vendor/hak-ats-plugin",
    "@hiero-ledger/sdk": "^2.81.0",
    "@langchain/core": "^1.1.48",
    "@langchain/google-genai": "^2.1.31",
    "@langchain/langgraph": "^1.3.2",
    "@langchain/openai": "^1.4.7",
    "dotenv": "^16.4.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/node": "^20.0.0",
    "eslint": "^9.0.0",
    "prettier": "^3.4.0",
    "tsx": "^4.19.0",
    "typescript": "^5.9.0",
    "typescript-eslint": "^8.60.0"
  },
  "engines": {
    "node": ">=20"
  },
  "overrides": {
    "@langchain/core": "$@langchain/core"
  }
}
